{
  "description": "Guardian checks package additions before shell install commands run.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/preinstall_gate.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
